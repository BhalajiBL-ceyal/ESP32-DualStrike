void sendToESP1(const char* msg) {
  size_t l = strlen(msg);
  if (l > 250) l = 250;
  esp_now_send(ESP1_MAC, (uint8_t*)msg, l);
  Serial.printf("[TX] %s\n", msg);
}

void reinitEspNow() {
  esp_now_deinit();
  delay(150);
  // Must be in STA mode for ESP-NOW to work after a scan
  WiFi.mode(WIFI_STA);
  WiFi.disconnect(false, true); // disconnect but keep STA mode, don't erase creds
  delay(100);
  if (esp_now_init() != ESP_OK) {
    Serial.println("[ESP-NOW] reinit FAILED");
    return;
  }
  esp_now_register_recv_cb(OnDataRecv);
  memset(&peerInfo, 0, sizeof(peerInfo));
  memcpy(peerInfo.peer_addr, ESP1_MAC, 6);
  peerInfo.channel = 1;  // ESP1 AP is always on channel 1
  peerInfo.encrypt = false;
  peerInfo.ifidx   = WIFI_IF_STA;
  if (esp_now_add_peer(&peerInfo) != ESP_OK) {
    Serial.println("[ESP-NOW] re-add peer FAILED");
  } else {
    Serial.println("[ESP-NOW] reinit OK");
  }
}

bool parseMac(const char* str, uint8_t* mac) {
  return sscanf(str, "%hhx:%hhx:%hhx:%hhx:%hhx:%hhx",
    &mac[0],&mac[1],&mac[2],&mac[3],&mac[4],&mac[5]) == 6;
}

void macStr(const uint8_t* m, char* out) {
  sprintf(out, "%02X:%02X:%02X:%02X:%02X:%02X",
    m[0],m[1],m[2],m[3],m[4],m[5]);
}

// ── Base64 encoder for PCAP download
static const char B64[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
int b64Encode(const uint8_t* in, int inLen, char* out) {
  int o = 0;
  for (int i = 0; i < inLen; i += 3) {
    uint32_t b = (uint32_t)in[i] << 16;
    if (i+1 < inLen) b |= (uint32_t)in[i+1] << 8;
    if (i+2 < inLen) b |= in[i+2];
    out[o++] = B64[(b>>18)&0x3F];
    out[o++] = B64[(b>>12)&0x3F];
    out[o++] = (i+1 < inLen) ? B64[(b>>6)&0x3F] : '=';
    out[o++] = (i+2 < inLen) ? B64[b&0x3F]       : '=';
  }
  out[o] = 0;
  return o;
}

// ── Write PCAP global header into hsBuf
void initPcap() {
  if (!hsBuf) hsBuf = (uint8_t*)malloc(HS_MAX);
  if (!hsBuf) return;
  hsBufLen = 0;
  hsEapolCount = 0;
  // Global header
  uint32_t magic = 0xA1B2C3D4;
  uint16_t vmaj = 2, vmin = 4;
  int32_t  zone = 0;
  uint32_t sigs = 0, snap = 65535, net = 105; // IEEE 802.11
  memcpy(hsBuf+hsBufLen, &magic, 4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &vmaj,  2); hsBufLen += 2;
  memcpy(hsBuf+hsBufLen, &vmin,  2); hsBufLen += 2;
  memcpy(hsBuf+hsBufLen, &zone,  4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &sigs,  4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &snap,  4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &net,   4); hsBufLen += 4;
}

void appendPcapPkt(const uint8_t* data, int len) {
  if (!hsBuf || hsBufLen + 16 + len > HS_MAX) return;
  uint32_t ts_s  = millis() / 1000;
  uint32_t ts_us = (millis() % 1000) * 1000;
  uint32_t l     = (uint32_t)len;
  memcpy(hsBuf+hsBufLen, &ts_s,  4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &ts_us, 4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &l,     4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, &l,     4); hsBufLen += 4;
  memcpy(hsBuf+hsBufLen, data,   len); hsBufLen += len;
}

// ══════════════════════════════════════════════
//  SNIFFER CALLBACK (ISR — keep it minimal)
// ══════════════════════════════════════════════
void IRAM_ATTR snifferCb(void* buf, wifi_promiscuous_pkt_type_t type) {
  wifi_promiscuous_pkt_t* p = (wifi_promiscuous_pkt_t*)buf;
  pktCount++;
  lastRSSI = p->rx_ctrl.rssi;
  lastChan = p->rx_ctrl.channel;

  // EAPOL detection for handshake capture
  if (hsRunning && !hsPktReady && type == WIFI_PKT_DATA) {
    // sig_len includes FCS (4 bytes) — strip it
    int len = p->rx_ctrl.sig_len;
    if (len > 4) len -= 4;  // remove FCS
    if (len < 28 || len > 400) return;

    uint8_t* pl = p->payload;
    uint16_t fc = *(uint16_t*)pl;

    // Frame Control: bit8=ToDS, bit9=FromDS
    bool toDS   = (fc >> 8) & 0x01;
    bool fromDS = (fc >> 8) & 0x02;
    // QoS bit: subtype bits [7:4] >= 8
    bool isQos  = ((fc >> 4) & 0x0F) >= 8;
    int hdrLen  = isQos ? 26 : 24;
    if (len <= hdrLen + 8) return;

    // Determine BSSID position based on ToDS/FromDS
    // ToDS=0, FromDS=0: addr3=BSSID
    // ToDS=1, FromDS=0: addr1=BSSID (infra uplink)
    // ToDS=0, FromDS=1: addr2=BSSID (infra downlink)
    // ToDS=1, FromDS=1: WDS — check addr1 and addr2
    uint8_t* bssid_in_frame;
    if (!toDS && !fromDS)  bssid_in_frame = pl + 16;  // addr3
    else if (toDS && !fromDS) bssid_in_frame = pl + 4;  // addr1=AP
    else                   bssid_in_frame = pl + 10;  // addr2=AP

    uint8_t* llc = pl + hdrLen;
    // LLC SNAP header: AA AA 03 xx xx xx ET ET
    if (llc[0] == 0xAA && llc[1] == 0xAA && llc[6] == 0x88 && llc[7] == 0x8E) {
      if (memcmp(bssid_in_frame, hsBSSID, 6) == 0 || hsBSSID[0] == 0xFF) {
        memcpy(hsTmpPkt, pl, len);
        hsTmpLen = (uint16_t)len;
        hsPktReady = true;
      }
    }
  }
}

